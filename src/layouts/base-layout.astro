---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
import BackgroundBlobs from '../components/background-blobs.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = 'Dam Hong Phuc — AI Full-stack Engineer | Conversational AI Agents',
  description = 'AI Full-stack Engineer specializing in production Conversational AI Agents for enterprises, with deep expertise in HR & Legal workflows.',
  image = '/og/landing.png',
  canonical = Astro.url.href,
} = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://maver1ch.github.io/';
const ogImage = new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="color-scheme" content="light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Dam Hong Phuc" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (match HTI page + variable weights) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="scroll-progress" id="scroll-progress"></div>
    <BackgroundBlobs />
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // ===== Reveal-on-scroll =====
      // Activate JS-only hidden state, then observe for intersection.
      // Failsafe: reveal anything already in viewport at setup time,
      // and force-reveal everything after 2.5s in case the observer misses.
      const setupReveals = () => {
        document.documentElement.classList.add('js-ready');
        const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)'));
        if (els.length === 0) return;

        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -5% 0px' }
        );

        // Eagerly reveal anything within 4 viewport heights — covers most pages
        // for fast first paint, screenshot tools, and reduced-motion users.
        const eagerRange = window.innerHeight * 4;
        els.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < eagerRange) {
            el.classList.add('is-visible');
          } else {
            obs.observe(el);
          }
        });

        // Final failsafe — force-reveal anything still hidden after 1.2s
        window.setTimeout(() => {
          document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => {
            el.classList.add('is-visible');
          });
        }, 1200);
      };

      // ===== Scroll progress =====
      const setupProgress = () => {
        const bar = document.getElementById('scroll-progress');
        if (!bar) return;
        const update = () => {
          const h = document.documentElement;
          const scrolled = h.scrollTop;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (scrolled / max) * 100 : 0;
          bar.style.width = pct + '%';
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
      };

      const init = () => {
        setupReveals();
        setupProgress();
      };

      init();
      // Re-init after view transitions
      document.addEventListener('astro:page-load', init);
    </script>
  </body>
</html>
