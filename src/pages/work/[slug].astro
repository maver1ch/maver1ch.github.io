---
import { getCollection, render } from 'astro:content';
import CaseStudyLayout from '../../layouts/case-study-layout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('work', ({ data }) => !data.draft);
  return studies.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, client, period, role, tldr, stack, metrics } = entry.data;
---

<CaseStudyLayout
  title={title}
  client={client}
  period={period}
  role={role}
  tldr={tldr}
  stack={stack}
  metrics={metrics}
>
  <Content />
</CaseStudyLayout>
