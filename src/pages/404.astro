---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout
  title="Page not found — Dam Hong Phuc"
  description="The page you're looking for doesn't exist. Head back to the homepage or jump straight to the case studies."
>
  <section class="not-found">
    <div class="not-found-inner">
      <span class="error-code">404</span>
      <h1 class="error-title">Page not found</h1>
      <p class="error-lede">
        The page you're looking for has moved or never existed. Try one of these instead.
      </p>

      <div class="action-row">
        <a href="/" class="primary-action">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to home
        </a>
        <a href="/#work" class="secondary-action">View case studies</a>
      </div>

      <ul class="quick-links" aria-label="Quick links to case studies">
        <li><a href="/work/hti-agentic-chatbot/">Enterprise HR Agentic Chatbot</a></li>
        <li><a href="/work/fpt-hr-conversational-ai/">HR Conversational AI Platform</a></li>
        <li><a href="/work/fpt-contract-intelligence/">AI Contract Intelligence System</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 5% 4rem;
  }

  .not-found-inner {
    max-width: 640px;
    text-align: center;
  }

  .error-code {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: clamp(5rem, 12vw, 8rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary) 60%, var(--color-accent-tertiary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .error-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
  }

  .error-lede {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  .action-row {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .primary-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.45rem;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.22);
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .primary-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(37, 99, 235, 0.32);
  }
  .secondary-action {
    padding: 0.85rem 1.25rem;
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid rgba(15, 23, 42, 0.12);
    transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .secondary-action:hover {
    background: rgba(37, 99, 235, 0.06);
    border-color: rgba(37, 99, 235, 0.32);
  }

  .quick-links {
    list-style: none;
    margin: 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid rgba(15, 23, 42, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .quick-links a {
    color: var(--color-accent-primary);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .quick-links a:hover {
    color: var(--color-accent-secondary);
  }
</style>
