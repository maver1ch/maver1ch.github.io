---
import GlassCard from '../glass-card.astro';

const channels = [
  {
    label: 'Email',
    value: 'damhongphuc.4104@gmail.com',
    href: 'mailto:damhongphuc.4104@gmail.com',
    icon: 'mail',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/damhongphuc',
    href: 'https://www.linkedin.com/in/damhongphuc/',
    icon: 'linkedin',
  },
  {
    label: 'GitHub',
    value: 'github.com/maver1ch',
    href: 'https://github.com/maver1ch',
    icon: 'github',
  },
  {
    label: 'Upwork',
    value: 'Available for contract',
    href: 'https://www.upwork.com/freelancers/~damhongphuc',
    icon: 'upwork',
  },
];
---

<section class="contact" id="contact">
  <div class="contact-inner">
    <header class="section-header">
      <h2 class="section-title">
        Let&rsquo;s build <span class="grad">something</span>.
      </h2>
      <p class="section-lede">
        Open to contract work on production RAG, multi-agent systems, and AWS-native AI
        infrastructure. Reach out via any channel below.
      </p>
    </header>

    <GlassCard hover={false} class="contact-card" glow>
      <ul class="channel-list">
        {channels.map(({ label, value, href, icon }) => (
          <li>
            <a href={href} target="_blank" rel="noopener noreferrer" class="channel">
              <span class="channel-icon" aria-hidden="true">
                {icon === 'mail' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="5" width="18" height="14" rx="2"/>
                    <path d="m3 7 9 6 9-6"/>
                  </svg>
                )}
                {icon === 'linkedin' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.03-1.85-3.03-1.85 0-2.13 1.45-2.13 2.94v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.62 0 4.29 2.38 4.29 5.48v6.26zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/>
                  </svg>
                )}
                {icon === 'github' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.1.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"/>
                  </svg>
                )}
                {icon === 'upwork' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.212 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112a2.668 2.668 0 0 1-2.665 2.665 2.668 2.668 0 0 1-2.665-2.665V3.492H0v7.112c0 2.846 2.318 5.165 5.164 5.165 2.844 0 5.162-2.319 5.162-5.165v-1.19c.534 1.027 1.214 2.067 2.046 2.989l-1.751 8.245h2.738l1.273-5.999c1.123.71 2.413 1.171 3.83 1.171 3.108 0 5.518-2.51 5.538-5.5 0-2.998-2.42-5.302-5.439-5.302z"/>
                  </svg>
                )}
              </span>
              <span class="channel-meta">
                <span class="channel-label">{label}</span>
                <span class="channel-value">{value}</span>
              </span>
              <span class="channel-arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7M17 7H8M17 7V16"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </GlassCard>
  </div>
</section>

<style>
  .contact {
    padding: 6rem 5% 8rem;
  }

  .contact-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.25rem;
  }
  .eyebrow-line {
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent-primary), var(--color-accent-secondary));
  }
  .eyebrow-text {
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent-primary);
  }

  .section-title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.15;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
    padding-bottom: 0.05em;
  }
  .grad {
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary) 60%, var(--color-accent-tertiary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-lede {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .primary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.65rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    color: white;
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    box-shadow: var(--shadow-glow-primary), 0 6px 18px rgba(37, 99, 235, 0.22);
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .primary-cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-secondary), 0 12px 32px rgba(37, 99, 235, 0.32);
  }
  .primary-cta:active { transform: translateY(0) scale(0.98); }
  .cta-email {
    color: var(--color-text-secondary);
    font-family: var(--font-mono), ui-monospace, monospace;
    font-size: 0.9rem;
  }

  .channel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .channel {
    display: grid;
    grid-template-columns: 2.75rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-md);
    transition:
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .channel:hover {
    background: rgba(37, 99, 235, 0.06);
    transform: translateX(4px);
  }

  .channel-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    background: rgba(37, 99, 235, 0.08);
    color: var(--color-accent-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }
  .channel:hover .channel-icon {
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    color: white;
  }

  .channel-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
    min-width: 0;
  }
  .channel-label {
    color: var(--color-text-primary);
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: 0.95rem;
  }
  .channel-value {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .channel-arrow {
    color: var(--color-text-tertiary);
    display: inline-flex;
    transition: transform var(--duration-base) var(--ease-spring), color var(--duration-fast) var(--ease-out);
  }
  .channel:hover .channel-arrow {
    color: var(--color-accent-primary);
    transform: translate(3px, -3px);
  }
</style>
