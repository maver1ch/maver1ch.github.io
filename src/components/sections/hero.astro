---
---

<section class="hero" id="hero">
  <div class="hero-grid-frame" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="status-pill">
      <span class="status-dot" aria-hidden="true"></span>
      <span>Available for contract work</span>
    </div>

    <div class="hero-main">
      <!-- LEFT column: identity + CTA -->
      <div class="hero-left">
        <h1 class="hero-title">Dam Hong Phuc</h1>
        <p class="hero-tagline">AI Full-stack Engineer</p>

        <div class="hero-cta-row">
          <a href="#work" class="cta-primary">
            <span>View Work</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
          <a href="/resume.pdf" class="cta-resume" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            <span>Resume</span>
          </a>
        </div>
      </div>

      <!-- RIGHT column: value prop + highlight -->
      <div class="hero-right">
        <p class="hero-subtitle">
          I build production-grade <strong>Conversational AI Agents</strong> for enterprises, with deep expertise in <strong>HR &amp; Legal</strong> workflows.
        </p>

        <div class="fortune-callout">
          <svg class="callout-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
          </svg>
          <div class="callout-text">
            <span class="callout-kicker">Shipped at</span>
            <span class="callout-headline">Fortune 500 scale</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom row: 3 stat cards full width -->
    <div class="hero-meta tabular">
      <div class="meta-card">
        <span class="meta-value">3+</span>
        <span class="meta-label">Years building<br/>production AI</span>
      </div>
      <div class="meta-card">
        <span class="meta-value">4</span>
        <span class="meta-label">Enterprise<br/>case studies</span>
      </div>
      <div class="meta-card">
        <span class="meta-value">AWS</span>
        <span class="meta-label">Certified Solutions<br/>Architect (SAA)</span>
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    padding: 7rem 5% 4rem;
    position: relative;
  }

  /* Decorative gradient-border frame */
  .hero-grid-frame {
    position: absolute;
    inset: 6rem 5% 4rem;
    border-radius: var(--radius-2xl);
    pointer-events: none;
    border: 1px solid transparent;
    background:
      linear-gradient(180deg, transparent, transparent) padding-box,
      linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(14, 165, 233, 0.22), rgba(6, 182, 212, 0.22)) border-box;
    opacity: 0.55;
    mask: linear-gradient(180deg, transparent, black 15%, black 85%, transparent);
    -webkit-mask: linear-gradient(180deg, transparent, black 15%, black 85%, transparent);
  }

  .hero-inner {
    position: relative;
    max-width: 1240px;
    width: 100%;
    margin: 0 auto;
    animation: fade-in-up 700ms var(--ease-premium) both;
  }

  /* Status pill — top center */
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(34, 197, 94, 0.10);
    border: 1px solid rgba(34, 197, 94, 0.22);
    color: #15803d;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
  }
  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.22);
    animation: pulse-dot 2s var(--ease-out) infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.22); }
    50%      { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0.08); }
  }

  /* Two-column main row */
  .hero-main {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 1.25fr);
    gap: 3.5rem;
    align-items: stretch;
    text-align: left;
    margin-bottom: 3rem;
  }

  /* LEFT — identity */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.045em;
    margin: 0;
    padding-bottom: 0.05em;
    background: linear-gradient(135deg, #0f172a 0%, #0ea5e9 60%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 100%;
    background-position: 0% 50%;
    transition: background-position 800ms var(--ease-premium);
  }
  .hero-title:hover { background-position: 100% 50%; }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    font-weight: 500;
    color: #4b5563;
    letter-spacing: 0.18em;
    margin: 0.75rem 0 1.25rem;
    text-transform: uppercase;
  }

  .hero-cta-row {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 170px;
    padding: 0.9rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.97rem;
    color: white;
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    box-shadow: var(--shadow-glow-primary), 0 4px 12px rgba(37, 99, 235, 0.20);
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }

  .cta-resume {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 170px;
    padding: 0.9rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.97rem;
    color: var(--color-accent-primary);
    background: #ffffff;
    border: 1px solid rgba(37, 99, 235, 0.28);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 4px 12px rgba(37, 99, 235, 0.08);
    transition: transform var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .cta-resume:hover {
    transform: translateY(-2px);
    border-color: rgba(37, 99, 235, 0.55);
    box-shadow: 0 4px 8px rgba(15, 23, 42, 0.04), 0 12px 28px rgba(37, 99, 235, 0.18);
  }
  .cta-resume:active { transform: translateY(0) scale(0.98); }
  .cta-resume svg { transition: transform var(--duration-base) var(--ease-spring); }
  .cta-resume:hover svg { transform: translateY(-1px); }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-secondary), 0 12px 32px rgba(37, 99, 235, 0.30);
  }
  .cta-primary:active { transform: translateY(0) scale(0.98); }
  .cta-primary svg { transition: transform var(--duration-base) var(--ease-spring); }
  .cta-primary:hover svg { transform: translateX(4px); }

  /* RIGHT — value prop */
  .hero-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    padding-left: 2rem;
    border-left: 1px solid rgba(15, 23, 42, 0.08);
  }

  .hero-subtitle {
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    line-height: 1.5;
    color: var(--color-text-primary);
    margin: 0;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .hero-subtitle strong {
    color: var(--color-accent-primary);
    font-weight: 600;
  }

  /* Fortune 500 callout — soft glassmorphism, no harsh border */
  .fortune-callout {
    display: inline-flex;
    align-items: center;
    gap: 0.95rem;
    padding: 1rem 1.35rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.05), rgba(14, 165, 233, 0.06), rgba(6, 182, 212, 0.06));
    border: 1px solid rgba(14, 165, 233, 0.12);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    box-shadow: var(--shadow-sm);
    align-self: flex-start;
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out);
  }
  .fortune-callout:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .callout-icon {
    color: var(--color-accent-secondary);
    flex-shrink: 0;
  }
  .callout-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .callout-kicker {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #4b5563;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .callout-headline {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #0369a1;
  }

  /* Meta cards — 3 compact cards, content centered */
  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .meta-card {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.95rem 1rem;
    border-radius: var(--radius-xl);
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    backdrop-filter: blur(14px);
    box-shadow: var(--shadow-xs);
    text-align: left;
    transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }
  .meta-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: rgba(37, 99, 235, 0.2);
  }
  .meta-value {
    font-family: var(--font-heading);
    font-size: clamp(1.85rem, 2.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-accent-primary), var(--color-accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: nowrap;
  }
  .meta-unit {
    font-size: 0.7em;
    opacity: 0.7;
    font-weight: 600;
  }
  .meta-label {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .hero-main {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }
    .hero-left { align-items: center; }
    .hero-right {
      padding-left: 0;
      border-left: none;
      padding-top: 2rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
      align-items: center;
    }
    .fortune-callout { align-self: center; }
  }

  @media (max-width: 720px) {
    .hero-meta { grid-template-columns: 1fr; gap: 0.7rem; }
    .meta-card { padding: 0.95rem 1.1rem; }
    .hero-grid-frame { display: none; }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-text-tertiary);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: bob 2.5s var(--ease-out) infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 8px); }
  }
</style>
