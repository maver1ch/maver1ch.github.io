---
import { classifySkill } from '../data/skill-categories.ts';
import { iconFor, ICON_PATHS } from '../data/tool-icons.ts';

interface Props {
  label: string;
  /** Visual category determining the *hover* accent color. Auto-detected if omitted. */
  category?: 'lang' | 'framework' | 'cloud' | 'db' | 'concept' | 'neutral';
  /** Show a small leading icon. Defaults to true. */
  icon?: boolean;
}

const { label, category, icon = true } = Astro.props;
const cat = category ?? classifySkill(label);
const iconKey = iconFor(label);
const iconPath = ICON_PATHS[iconKey];
---

<span class:list={['stack-pill', `pill-${cat}`]}>
  {icon && (
    <svg
      class="pill-icon"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={iconPath}
    />
  )}
  <span class="pill-label">{label}</span>
</span>

<style>
  .stack-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.32rem 0.7rem;
    border-radius: var(--radius-sm);
    background: rgba(15, 23, 42, 0.05);
    border: 1px solid rgba(15, 23, 42, 0.07);
    color: #475569; /* slate-600 default — monochrome */
    font-size: 0.78rem;
    font-weight: 500;
    font-family: var(--font-heading);
    letter-spacing: 0.01em;
    transition:
      background var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
    cursor: default;
  }
  .pill-icon {
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }
  .stack-pill:hover {
    transform: translateY(-1px);
  }
  .stack-pill:hover .pill-icon {
    opacity: 1;
  }

  /* On hover, each category transitions to its own brand color */
  .pill-lang:hover {
    background: rgba(14, 165, 233, 0.10);
    border-color: rgba(14, 165, 233, 0.35);
    color: #0369a1;
  }
  .pill-framework:hover {
    background: rgba(14, 165, 233, 0.10);
    border-color: rgba(14, 165, 233, 0.35);
    color: var(--color-accent-secondary);
  }
  .pill-cloud:hover {
    background: rgba(6, 182, 212, 0.14);
    border-color: rgba(6, 182, 212, 0.45);
    color: #0e7490;
  }
  .pill-db:hover {
    background: rgba(20, 184, 166, 0.12);
    border-color: rgba(20, 184, 166, 0.40);
    color: #0f766e;
  }
  .pill-concept:hover {
    background: rgba(6, 182, 212, 0.10);
    border-color: rgba(6, 182, 212, 0.35);
    color: #0e7490;
  }
  .pill-neutral:hover {
    background: rgba(15, 23, 42, 0.08);
    border-color: rgba(15, 23, 42, 0.15);
    color: var(--color-text-primary);
  }
</style>
