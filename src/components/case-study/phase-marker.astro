---
interface Props {
  label: string;
  highlight?: boolean;
}

const { label, highlight = false } = Astro.props;
---

<div class:list={['phase-marker', { highlight }]}>
  <span class="phase-line" aria-hidden="true"></span>
  <h3 class="phase-label">
    <span class="phase-dot" aria-hidden="true"></span>{label}
  </h3>
  <span class="phase-line" aria-hidden="true"></span>
</div>

<style>
  .phase-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    margin: 5rem auto 1.75rem;
    max-width: 100%;
  }

  .phase-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(15, 23, 42, 0.14) 50%, transparent);
    /* Match the dot's cap-center shift so all three elements share the same baseline */
    font-size: 0.95rem;
    position: relative;
    top: 0.05em;
  }

  .phase-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-text-secondary);
    margin: 0;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
  }

  /* Dot lives inline with the label text so it tracks cap-height, not box-height */
  .phase-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent-primary);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
    margin-right: 0.85em;
    flex-shrink: 0;
    /* Sits at cap-middle of uppercase text without depending on em-box geometry */
    position: relative;
    top: 0.05em;
  }

  .phase-marker.highlight .phase-dot {
    background: var(--color-accent-tertiary);
    box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.15);
  }

  .phase-marker.highlight .phase-label {
    color: var(--color-accent-tertiary);
  }

  @media (max-width: 600px) {
    .phase-label {
      font-size: 0.82rem;
      letter-spacing: 0.18em;
      white-space: normal;
      text-align: center;
    }
  }
</style>
