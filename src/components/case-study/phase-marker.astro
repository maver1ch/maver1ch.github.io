---
interface Props {
  label: string;
  highlight?: boolean;
}

const { label, highlight = false } = Astro.props;
---

<div class:list={['phase-marker', { highlight }]}>
  <span class="phase-dot" aria-hidden="true"></span>
  <h3 class="phase-label">{label}</h3>
</div>

<style>
  .phase-marker {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 5rem 0 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .phase-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent-primary);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
    flex-shrink: 0;
  }

  .phase-marker.highlight .phase-dot {
    background: var(--color-accent-tertiary);
    box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.15);
  }

  .phase-label {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .phase-marker.highlight .phase-label {
    color: var(--color-accent-tertiary);
  }
</style>
