---
import ZoomableImage from './zoomable-image.astro';

interface Props {
  step: string;
  title: string;
  image: string;
  alt: string;
  reverse?: boolean;
  highlight?: boolean;
}

const { step, title, image, alt, reverse = false, highlight = false } = Astro.props;
---

<article class:list={['arch-section', { reverse, highlight }]}>
  <div class="arch-text">
    <div class:list={['step-num', { 'step-highlight': highlight }]}>{step}</div>
    <h2 class="arch-title">{title}</h2>
    <div class="arch-body">
      <slot />
    </div>
  </div>
  <div class="arch-visual">
    <ZoomableImage src={image} alt={alt} />
  </div>
</article>

<style>
  .arch-section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: center;
    margin: 4rem 0;
  }

  .arch-section.reverse {
    grid-template-columns: 1.2fr 1fr;
  }

  .arch-section.reverse .arch-text {
    order: 2;
  }

  .arch-section.reverse .arch-visual {
    order: 1;
  }

  .step-num {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    color: rgba(37, 99, 235, 0.15);
    margin-bottom: 0.5rem;
  }

  .step-num.step-highlight {
    color: rgba(6, 182, 212, 0.25);
  }

  .arch-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .arch-body :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .arch-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .arch-body :global(ul),
  .arch-body :global(ol) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .arch-body :global(li) {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .arch-section,
    .arch-section.reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .arch-section.reverse .arch-text,
    .arch-section.reverse .arch-visual {
      order: initial;
    }
  }
</style>
