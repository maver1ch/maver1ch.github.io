---
import ZoomableImage from './zoomable-image.astro';

interface Props {
  step: string;
  title: string;
  image: string;
  alt: string;
  highlight?: boolean;
  challenge?: string;
}

const {
  step,
  title,
  image,
  alt,
  highlight = false,
  challenge,
} = Astro.props;

// Zigzag rhythm driven by step parity: odd → text-left, even → image-left
const stepNum = parseInt(step, 10);
const isReverse = !isNaN(stepNum) && stepNum % 2 === 0;
---

<article class:list={['arch-section', { reverse: isReverse, highlight }]}>
  <div class="arch-text">
    <div class="arch-text-inner">
      <span class:list={['step-num', { 'step-highlight': highlight }]}>
        <span class="step-num-label">Step</span>
        <span class="step-num-value">{step}</span>
      </span>
      <h2 class="arch-title">{title}</h2>
      {challenge && (
        <p class="arch-challenge">
          <span class="challenge-label">Challenge</span>
          <span class="challenge-text">{challenge}</span>
        </p>
      )}
      <div class="arch-body">
        {challenge && <span class="solution-label" aria-hidden="true">Solution</span>}
        <slot />
      </div>
    </div>
  </div>
  <div class="arch-visual">
    <div class="arch-visual-inner">
      <ZoomableImage src={image} alt={alt} />
    </div>
  </div>
</article>

<style>
  /* Sticky asymmetric grid.
     KEY: align-items defaults to `stretch` so both columns share row height
     (= max of both contents). Each column then flex-centers its inner wrapper
     vertically — when image is much shorter than text, image floats in the
     middle of its column instead of stranding empty space at the bottom.
     Sticky works because the stretched column is the containing block, which
     is taller than the inner wrapper.
     No `overflow:hidden` anywhere up the tree or sticky breaks. */
  .arch-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    margin: 5rem 0;
  }

  .arch-section.reverse .arch-text { order: 2; }
  .arch-section.reverse .arch-visual { order: 1; }

  .arch-text,
  .arch-visual {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .arch-text-inner,
  .arch-visual-inner {
    position: sticky;
    top: 100px;
  }

  /* Step eyebrow — premium badge style instead of a pale watermark */
  .step-num {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-heading);
    line-height: 1;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .step-num-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--color-text-tertiary);
  }
  .step-num-value {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-accent-primary);
  }
  .step-num.step-highlight .step-num-value {
    color: var(--color-accent-tertiary);
  }

  .arch-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  /* Challenge → Solution structured framing */
  .arch-challenge {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem;
    margin: 0 0 1.1rem;
    background: linear-gradient(90deg, rgba(244, 63, 94, 0.05), transparent 80%);
    border-left: 3px solid rgba(244, 63, 94, 0.55);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .challenge-label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(190, 18, 60);
  }
  .challenge-text {
    color: var(--color-text-primary);
    font-size: 1rem;
    line-height: 1.65;
  }
  .solution-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent-primary);
    margin-bottom: 0.5rem;
  }

  /* MDX body typography (rendered into <slot/>) */
  .arch-body :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .arch-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .arch-body :global(ul),
  .arch-body :global(ol) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .arch-body :global(li) {
    margin-bottom: 0.5rem;
  }

  /* Mobile: stack vertically, image on top, sticky disabled */
  @media (max-width: 768px) {
    .arch-section,
    .arch-section.reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .arch-section.reverse .arch-text,
    .arch-section.reverse .arch-visual {
      order: initial;
    }
    .arch-section .arch-visual { order: -1; }
    .arch-text,
    .arch-visual {
      display: block;
    }
    .arch-text-inner,
    .arch-visual-inner {
      position: static;
      top: auto;
    }
  }
</style>
