---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<figure class="zoomable-figure">
  <img
    src={src}
    alt={alt}
    class="zoomable-img"
    data-zoom
    decoding="async"
  />
  <span class="zoom-badge" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="7"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      <line x1="11" y1="8" x2="11" y2="14"/>
      <line x1="8" y1="11" x2="14" y2="11"/>
    </svg>
  </span>
</figure>

<style>
  .zoomable-figure {
    position: relative;
    margin: 0;
    padding: 0;
    border-radius: 0.85rem;
    overflow: hidden;
    background: transparent;
    border: 1px solid rgba(15, 23, 42, 0.06);
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
    cursor: zoom-in;
    transition: transform 0.35s var(--ease-premium), box-shadow 0.35s var(--ease-premium);
  }

  .zoomable-figure:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(15, 23, 42, 0.10);
  }

  .zoomable-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    transition: transform 0.5s var(--ease-premium);
  }

  .zoomable-figure:hover .zoomable-img {
    transform: scale(1.02);
  }

  /* Magnifier badge top-right — visible on hover, modern and subtle */
  .zoom-badge {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 0.6rem;
    background: rgba(15, 23, 42, 0.78);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: white;
    opacity: 0;
    transform: translateY(-4px) scale(0.92);
    transition:
      opacity 0.25s var(--ease-premium),
      transform 0.25s var(--ease-premium),
      background 0.2s ease;
    pointer-events: none;
  }

  .zoomable-figure:hover .zoom-badge {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>
